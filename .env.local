# .env.local
# Environment variables for local development mode.
# Copy this file to .env and adjust as needed.
# Never commit .env to version control.

POKER_ENV=local
POKER_HOST=127.0.0.1
POKER_PORT=5000
POKER_CONFIG_PATH=config/house_rules.json
POKER_DB_PATH=data/poker.db
POKER_LOG_LEVEL=DEBUG
POKER_CORS_ORIGINS=http://localhost:5173

# Frontend environment (used by Vite)
VITE_API_URL=http://localhost:5000
VITE_WS_URL=http://localhost:5000
